{
    "theme": "dark",
    "display": {
	"style": "powerline",
	"charset": "unicode",
	"colorCompatibility": "auto",
	"autoWrap": true,
	"lines": [
	    {
		"segments": {
		    "directory": {
			"enabled": true,
			"style": "full"
		    },
		    "git": {
			"enabled": true,
			"showSha": false,
			"showWorkingTree": true,
			"showOperation": false,
			"showTag": false,
			"showTimeSinceCommit": true,
			"showStashCount": false,
			"showUpstream": false,
			"showRepoName": false
		    }
		}
	    },
	    {
		"segments": {
		    "context": {
			"enabled": true,
			"showPercentageOnly": true
		    },
		    "block": {
			"enabled": true,
			"type": "weighted",
			"burnType": "cost"
		    }
		}
	    },
	    {
		"segments": {
		    "model": {
			"enabled": true
		    }
		}
	    }
	]
    },
    "budget": {
	"session": {
	    "warningThreshold": 80
	},
	"today": {
	    "amount": 5.0,
	    "warningThreshold": 80
	},
	"block": {
	    "amount": 20000000,
	    "type": "tokens",
	    "warningThreshold": 80
	}
    }
}
